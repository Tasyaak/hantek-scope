*.py[cod]
*$py.class

.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.hypothesis/
.tox/
.nox/
.dmypy.json
dmypy.json

# =========================================================
# Virtual environments
