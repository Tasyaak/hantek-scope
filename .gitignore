.DS_Store
Thumbs.db
Desktop.ini

# =========================================================
# Vendor SDK and vendor binaries
# Keep third-party SDK out of git history.
# The package can resolve it locally via HANTEK_DLL_DIR
# or via ./Hantek_SDK/Dll/x64
# =========================================================
Hantek_SDK/
*Hantek*SDK*.zip
*Hantek*SDK*.rar
*Hantek*SDK*.7z
HT600*SDK*.zip
HT600*SDK*.rar
HT600*SDK*.7z

# =========================================================
# Temporary local test outputs
# Uncomment or extend if your manual test scripts
# generate acquisition dumps or plots inside the repo.
# =========================================================
*.jpg
*.jpeg
*.svg
*.mp4

# =========================================================
# Optional local environment files
# =========================================================
.env
.env.*
.python-version